# Copy to .env and fill in production values.
# Never commit real secrets.

# SQLite path is relative to the prisma/ folder.
# Local:
DATABASE_URL="file:./dev.db"
# Railway example (optional absolute path):
# DATABASE_URL="file:./prod.db"

# Auth.js — REQUIRED in production (long random string)
AUTH_SECRET="replace-with-a-long-random-secret"

# Public site URL — REQUIRED in production (no trailing slash)
AUTH_URL="https://kat-production-c3d1.up.railway.app"

NODE_ENV="production"
