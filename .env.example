# Copy to .env and fill in production values.
# Never commit real secrets.

# SQLite (local) or Postgres connection string for production
DATABASE_URL="file:./dev.db"

# Auth.js — generate a long random string for production
# e.g. openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional: public site URL (recommended in production)
# AUTH_URL="https://your-domain.com"
