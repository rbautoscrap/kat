# Copy to .env and fill in values. Never commit real secrets.

# --- Local development ---
DATABASE_URL="file:./dev.db"

# --- Railway production (after attaching a Volume) ---
# 1) Railway Dashboard → 캣 service → right-click canvas or Settings
# 2) Add Volume, Mount Path MUST be: /app/data
# 3) Redeploy
#
# App stores:
#   /app/data/prod.db          ← members + listings (SQLite)
#   /app/data/uploads/         ← listing photos
#
# These are set automatically by start-prod when the Volume is attached:
# DATA_DIR=/app/data
# DATABASE_URL=file:/app/data/prod.db
# UPLOAD_DIR=/app/data/uploads

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="https://rbautotrade.com"
NODE_ENV="production"

# Railway injects RAILWAY_PUBLIC_DOMAIN automatically.
# Large backup ZIP restores upload directly to that origin (bypasses Cloudflare).
# Optional explicit override:
# RAILWAY_RESTORE_ORIGIN="https://kat-production-c3d1.up.railway.app"
# How many backup ZIPs to keep on the volume (default 25; ~250GB volume):
# BACKUP_MAX_COUNT=25

# Optional overrides:
# ADMIN_LOGIN=admin
# ADMIN_PASSWORD=KatAdmin#2026
