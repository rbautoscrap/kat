generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  AUTHORIZED
  ADMIN
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingCategory {
  HOT_DEALS
  CAR_LISTINGS
  LIVE_AUCTION
  STAND_BY
}

enum OfferCurrency {
  USD
  KRW
  EUR
}

enum ListingSaleStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  /** Phone / WhatsApp contact for admin follow-up (offers, etc.) */
  phone        String?
  role         Role            @default(MEMBER)
  /** Join sets PENDING; existing/seed accounts default to APPROVED. */
  status       AccountStatus   @default(APPROVED)
  /** Admin-only internal memo (shared among admins). */
  adminNote    String?
  createdAt    DateTime        @default(now())
  listings     Listing[]
  purchaseOffers PurchaseOffer[]
  /** Statements this admin created */
  createdStatements TransactionStatement[] @relation("StatementCreatedBy")
  /** Statements where this member is the linked buyer */
  purchasedStatements TransactionStatement[] @relation("StatementBuyer")
}

model Listing {
  id               String            @id @default(cuid())
  serialNumber     String            @unique
  title            String
  category         ListingCategory
  /** AVAILABLE = on sale, RESERVED = under contract, SOLD = sold out */
  saleStatus       ListingSaleStatus @default(AVAILABLE)
  year             Int
  make             String
  model            String
  vin              String?
  highlights       String?
  engineMark       String?
  displacement     String?
  transmission     String?
  engineStatus     String?
  odometer         String?
  damages          String?
  /** English translation of damages for public display */
  damagesEn        String?
  fuelType         String?
  exteriorColor    String?
  registrationDate String?
  youtubeUrl       String?
  whatsappNumber   String
  /** Admin-only internal reference (not shown publicly) */
  vehicleNumber    String?
  storageLocation  String?
  inboundDate      String?
  auctionPrice     String?
  incidentalCost   String?
  costPrice        String?
  accumulatedDays  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  authorId         String
  author           User            @relation(fields: [authorId], references: [id])
  images           ListingImage[]
  purchaseOffers   PurchaseOffer[]
  /** Primary listing on a statement (first line item) */
  transactionStatements TransactionStatement[]
  statementItems   TransactionStatementItem[]

  @@index([category, createdAt])
  @@index([saleStatus])
  @@index([authorId])
  @@index([createdAt])
}

/** Admin-issued transaction statement (거래명세서) */
model TransactionStatement {
  id             String        @id @default(cuid())
  statementNo    String        @unique
  /** First selected listing — kept for list preview / legacy rows (null if listing deleted) */
  listingId      String?
  listing        Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  /** Snapshot of the first line item (legacy + list preview) */
  vehicleLabel   String
  vin            String?
  serialNumber   String
  vehicleNumber  String?
  buyerName      String
  buyerPhone     String?
  buyerAddress   String?
  /** Optional link to a registered member (for purchase analytics). */
  buyerUserId    String?
  buyerUser      User?         @relation("StatementBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  /** Sum of line-item supply amounts */
  amount         String
  currency       OfferCurrency @default(KRW)
  /** true = 10% VAT included in total; false = zero-rated / no VAT */
  includeVat     Boolean       @default(true)
  issueDate      String
  notes          String?
  createdById    String
  createdBy      User          @relation("StatementCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          TransactionStatementItem[]

  @@index([listingId])
  @@index([issueDate])
  @@index([createdAt])
  @@index([createdById])
  @@index([buyerUserId])
}

/** One vehicle / line on a transaction statement */
model TransactionStatementItem {
  id            String               @id @default(cuid())
  statementId   String
  statement     TransactionStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  /** Null when the linked listing was deleted or this is an extra charge line */
  listingId     String?
  listing       Listing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  /** true = service / misc charge (not a vehicle listing) */
  isExtra       Boolean              @default(false)
  vehicleLabel  String
  vin           String?
  serialNumber  String
  vehicleNumber String?
  /** Supply amount for this line (before VAT) */
  amount        String
  sortOrder     Int                  @default(0)

  @@index([statementId, sortOrder])
  @@index([listingId])
}

/** Member purchase interest / bid for a listing */
model PurchaseOffer {
  id        String        @id @default(cuid())
  listingId String
  listing   Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    String
  currency  OfferCurrency
  /** Hashed client IP — blocks multi-account bids from same network */
  ipHash    String
  /** Stable browser device cookie — blocks multi-account bids from same browser */
  deviceId  String
  createdAt DateTime      @default(now())

  @@index([listingId, userId])
  @@index([listingId, ipHash])
  @@index([listingId, deviceId])
  @@index([listingId, createdAt])
}

model ListingImage {
  id        String  @id @default(cuid())
  url       String
  sortOrder Int     @default(0)
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

model SiteStats {
  id          String @id @default("main")
  totalVisits Int    @default(0)
  todayVisits Int    @default(0)
  todayDate   String @default("")
}
